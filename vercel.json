{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "server.mjs": {
      "includeFiles": [
        "index.html",
        "styles.css",
        "script.js",
        "assets/**",
        "robots.txt",
        "sitemap.xml"
      ]
    }
  },
  "rewrites": [
    {
      "source": "/zh-hant",
      "destination": "/index.html"
    },
    {
      "source": "/tr",
      "destination": "/index.html"
    },
    {
      "source": "/ms",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        }
      ]
    }
  ]
}
